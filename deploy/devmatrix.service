[Unit]
Description=DevMatrix Game Server
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=devmatrix
Group=devmatrix
WorkingDirectory=/home/Anirudh/devmatrix/server

ExecStart=/home/Anirudh/devmatrix/server/devmatrix

# Environment
EnvironmentFile=/home/Anirudh/devmatrix/server/.env

# Restart on failure
Restart=on-failure
RestartSec=5s

# Resource limits
LimitNOFILE=65536

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/home/Anirudh/devmatrix/server
PrivateTmp=true

[Install]
WantedBy=multi-user.target
