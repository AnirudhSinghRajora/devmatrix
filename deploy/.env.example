# Production environment variables for DevMatrix server.
# Copy to /opt/devmatrix/server/.env and fill in real values.

ADDR=:8080
DATABASE_URL=postgres://devmatrix_app:CHANGE_ME@localhost:5432/devmatrix?sslmode=require
JWT_SECRET=CHANGE_ME_TO_A_STRONG_SECRET
LLM_URL=http://localhost:8000
LLM_MODEL=google/gemma-2b-it
ALLOWED_ORIGINS=https://devmatrix.anirudhrajora.dev
MAX_PLAYERS=64
TICK_RATE=30
LLM_WORKERS=4
