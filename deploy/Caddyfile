# Caddyfile — Reverse proxy for DevMatrix
# Replace devmatrix.example.com with your actual domain.
# Caddy auto-provisions TLS via Let's Encrypt.

devmatrix.anirudhrajora.dev {
    # WebSocket — must be first.
    handle /ws {
        reverse_proxy localhost:8080
    }

    # REST API routes.
    handle /api/* {
        reverse_proxy localhost:8080
    }

    # Monitoring endpoints.
    handle /health {
        reverse_proxy localhost:8080
    }
    handle /debug/* {
        reverse_proxy localhost:8080
    }

    # SPA fallback: serve static files, fall back to index.html.
    handle {
        root * /home/Anirudh/devmatrix/client/dist
        try_files {path} /index.html
        file_server
    }

    # Compression.
    encode gzip zstd

    # Security headers.
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }
}
